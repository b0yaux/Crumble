#!/bin/zsh
# hap-dl: Download and encode media for A/V performance (HAP/MJPEG)
# Supports YouTube, Instagram, Vimeo, and anything yt-dlp handles.

set -e

COOKIE_FILE="${HAP_DL_COOKIES:-$HOME/.config/hap-dl/cookies.txt}"
HAP_DL_BROWSER="${HAP_DL_BROWSER:-firefox}"

check_dependencies() {
    if ! command -v yt-dlp &> /dev/null; then
        echo "yt-dlp missing. Installing via Homebrew..."
        brew install yt-dlp
    fi

    if ! ffmpeg -encoders 2>/dev/null | grep -q "hap"; then
        echo "FFmpeg with HAP support not found. Installing ffmpeg-full..."
        if command -v brew &> /dev/null; then
            brew install ffmpeg-full
            brew link ffmpeg-full --force
        else
            echo "Error: Homebrew not found. Please install ffmpeg with HAP support manually."
            exit 1
        fi
    fi
}

is_instagram() {
    [[ "$1" == *instagram.com* ]]
}

yt_args() {
    local url="$1"
    local base_args=()

    if is_instagram "$url"; then
        if [[ -f "$COOKIE_FILE" ]]; then
            base_args+=(--cookies "$COOKIE_FILE")
        else
            # Default to chrome if no cookie file
            base_args+=(--cookies-from-browser "$HAP_DL_BROWSER")
        fi
    fi

    echo "${base_args[@]}"
}

convert_video() {
    local url="$1"
    local target_path="$2"
    local mode="$3"

    local target_dir=$(dirname "$target_path")
    mkdir -p "$target_dir"

    local extra_args=$(yt_args "$url")

    echo "Downloading: $url"
    yt-dlp $extra_args \
           -f "bestvideo[ext=mp4]+bestaudio[ext=m4a]/best[ext=mp4]/best" \
           -o "${target_path}.%(ext)s" \
           "$url"

    local downloaded=$(ls -t "${target_path}".* 2>/dev/null | head -1)

    if [[ -f "$downloaded" ]]; then
        local output_file="${target_path}.mov"

        if [[ "$mode" == "mjpeg" ]]; then
            echo "Converting to Photo-JPEG..."
            ffmpeg -i "$downloaded" -c:v mjpeg -q:v 3 -c:a pcm_s16le "$output_file" -y
            rm "$downloaded"
            echo "Done (MJPEG): $output_file"
        else
            echo "Converting to HAP..."
            if ffmpeg -i "$downloaded" -c:v hap -format hap_q -chunks 4 -c:a pcm_s16le "$output_file" -y; then
                rm "$downloaded"
                echo "Done (HAP): $output_file"
            else
                echo "HAP encoding failed. Falling back to Photo-JPEG..."
                local mjpeg_fallback="${output_file%.mov}_mjpeg.mov"
                ffmpeg -i "$downloaded" -c:v mjpeg -q:v 3 -c:a pcm_s16le "$mjpeg_fallback" -y
                rm "$downloaded"
                echo "Done (MJPEG): $mjpeg_fallback"
            fi
        fi
    else
        echo "Error: Download failed."
        exit 1
    fi
}

usage() {
    echo "Usage: hap-dl [options] <url> [output_path]"
    echo ""
    echo "Downloads media (YouTube, Instagram, Vimeo, etc.) and encodes to HAP or Photo-JPEG."
    echo ""
    echo "Instagram / Login:"
    echo "  By default, attempts to use cookies from Firefox: --cookies-from-browser firefox"
    echo "  You can change the browser: export HAP_DL_BROWSER=chrome"
    echo "  Or use a cookie file: export HAP_DL_COOKIES=~/.config/hap-dl/cookies.txt"
    echo ""
    echo "Examples:"
    echo "  hap-dl <url>                    Save with auto-title in current folder"
    echo "  hap-dl <url> clip               Save as 'clip.mov' in current folder"
    echo "  hap-dl <url> clips/v1           Save as 'v1.mov' in 'clips/' folder"
    echo "  hap-dl -q <instagram-reel>      Quick save with timestamp name"
    echo ""
    echo "Options:"
    echo "  -q, --quick    Use timestamp as name"
    echo "  -j, --jpeg     Force Photo-JPEG encoding"
    echo "  -h, --help     Show this help"
    exit 0
}

MODE="hap"
PATH_INPUT=""
URL=""
QUICK="false"

while [[ $# -gt 0 ]]; do
    case $1 in
        -h|--help) usage ;;
        -q|--quick) QUICK="true"; shift ;;
        -j|--jpeg) MODE="mjpeg"; shift ;;
        -*) echo "Unknown option: $1"; usage ;;
        *)
            if [[ -z "$URL" ]]; then
                URL="$1"
            elif [[ -z "$PATH_INPUT" ]]; then
                PATH_INPUT="$1"
            fi
            shift
            ;;
    esac
done

if [[ -z "$URL" ]]; then
    usage
fi

check_dependencies

if [[ "$QUICK" == "true" ]]; then
    FINAL_PATH="clip_$(date +%s)"
elif [[ -n "$PATH_INPUT" ]]; then
    FINAL_PATH="$PATH_INPUT"
else
    echo "Fetching title..."
    local extra_args=$(yt_args "$URL")
    FINAL_PATH=$(yt-dlp $extra_args --get-filename -o "%(title)s" "$URL" | tr '[:upper:]' '[:lower:]' | sed 's/[^a-z0-9]/_/g' | sed 's/__+/_/g' | sed 's/^_//' | sed 's/_$//')
fi

convert_video "$URL" "$FINAL_PATH" "$MODE"
