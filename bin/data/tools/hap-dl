#!/bin/zsh
# hap-dl: Download and encode media for A/V performance (HAP/MJPEG)
# Supports YouTube, Instagram, Vimeo, and anything yt-dlp handles.

set -e

SELF="${(%):-%x}"

COOKIE_FILE="${HAP_DL_COOKIES:-$HOME/.config/hap-dl/cookies.txt}"
HAP_DL_BROWSER="${HAP_DL_BROWSER:-firefox}"

check_dependencies() {
    if ! command -v yt-dlp &> /dev/null; then
        echo "yt-dlp missing. Installing via Homebrew..."
        brew install yt-dlp
    fi

    if ! ffmpeg -encoders 2>/dev/null | grep -q "hap"; then
        echo "FFmpeg with HAP support not found. Installing ffmpeg-full..."
        if command -v brew &> /dev/null; then
            brew install ffmpeg-full
            brew link ffmpeg-full --force
        else
            echo "Error: Homebrew not found. Please install ffmpeg with HAP support manually."
            exit 1
        fi
    fi
}

is_instagram() {
    [[ "$1" == *instagram.com* ]]
}

YT_ARGS=()

yt_args() {
    local url="$1"
    YT_ARGS=()

    if is_instagram "$url"; then
        if [[ -f "$COOKIE_FILE" ]]; then
            YT_ARGS+=(--cookies "$COOKIE_FILE")
        else
            YT_ARGS+=(--cookies-from-browser "$HAP_DL_BROWSER")
        fi
    fi
}

convert_video() {
    local url="$1"
    local target_path="$2"
    local mode="$3"

    local target_dir=$(dirname "$target_path")
    mkdir -p "$target_dir"

    yt_args "$url"

    echo "Downloading: $url"
    yt-dlp "${YT_ARGS[@]}" \
           -f "bestvideo[ext=mp4]+bestaudio[ext=m4a]/best[ext=mp4]/best" \
           -o "${target_path}.%(ext)s" \
           "$url"

    local downloaded=$(ls -t "${target_path}".* 2>/dev/null | head -1)

    if [[ -f "$downloaded" ]]; then
        local output_file="${target_path}.mov"

        if [[ "$mode" == "mjpeg" ]]; then
            echo "Converting to Photo-JPEG..."
            ffmpeg -i "$downloaded" -c:v mjpeg -q:v 3 -c:a pcm_s16le "$output_file" -y
            rm "$downloaded"
            echo "Done (MJPEG): $output_file"
        else
            echo "Converting to HAP..."
            if ffmpeg -i "$downloaded" -vf "scale=trunc(iw/4)*4:trunc(ih/4)*4" -c:v hap -format hap_q -chunks 4 -c:a pcm_s16le "$output_file" -y; then
                rm "$downloaded"
                echo "Done (HAP): $output_file"
            else
                echo "HAP encoding failed. Falling back to Photo-JPEG..."
                local mjpeg_fallback="${output_file%.mov}_mjpeg.mov"
                ffmpeg -i "$downloaded" -c:v mjpeg -q:v 3 -c:a pcm_s16le "$mjpeg_fallback" -y
                rm "$downloaded"
                echo "Done (MJPEG): $mjpeg_fallback"
            fi
        fi
    else
        echo "Error: Download failed."
        exit 1
    fi
}

clip_and_encode() {
    local url="$1"
    local target_path="$2"
    local mode="$3"
    local spec="$4"

    local target_dir
    target_dir=$(dirname "$target_path")
    mkdir -p "$target_dir"

    yt_args "$url"

    echo "Downloading: $url"
    yt-dlp "${YT_ARGS[@]}" \
           -f "bestvideo[ext=mp4]+bestaudio[ext=m4a]/best[ext=mp4]/best" \
           -o "${target_path}.%(ext)s" \
           "$url"

    local downloaded
    downloaded=$(ls -t "${target_path}".* 2>/dev/null | head -1)

    if [[ ! -f "$downloaded" ]]; then
        echo "Error: Download failed."
        exit 1
    fi

    local dur
    dur=$(ffprobe -v error -show_entries format=duration -of csv=p=0 "$downloaded" 2>/dev/null)
    if [[ -z "$dur" || "$dur" == "N/A" ]]; then
        dur=0
    fi
    dur=$(python3 -c "print(int(float('$dur')))" 2>/dev/null || echo 0)

    echo "Duration: ${dur}s"
    echo "Clip spec: $spec"

    python3 - "$downloaded" "$target_path" "$mode" "$dur" "$spec" << 'PYEOF'
import json, sys, subprocess, os, random, re

input_file, outpath, mode, total_dur, spec = (
    sys.argv[1], sys.argv[2], sys.argv[3], int(sys.argv[4]), sys.argv[5]
)

def get_clips(spec, dur):
    clips = []

    if spec.startswith("scatter:"):
        m = re.match(r"scatter:(\d+)x(\d+)(?:-(\d+))?", spec)
        if not m:
            print(f"Error: invalid scatter spec '{spec}'. Use scatter:NxS or scatter:NxMin-Max")
            sys.exit(1)
        count = int(m.group(1))
        min_len = int(m.group(2))
        max_len = int(m.group(3)) if m.group(3) else None
        if dur <= (min_len if max_len is None else min_len):
            length = min_len if max_len is None else random.randint(min_len, max_len)
            clips.append((0, length))
        else:
            # Use the max possible length to compute scatter positions
            effective_max = max_len if max_len else min_len
            margin = max(0, dur - effective_max)
            positions = sorted(random.sample(range(0, max(1, margin + 1)), min(count, margin + 1)))
            for pos in positions[:count]:
                length = min_len if max_len is None else random.randint(min_len, max_len)
                # Clamp: don't exceed video duration from this position
                length = min(length, dur - pos)
                clips.append((pos, length))

    elif spec.startswith("scene:"):
        max_len = int(spec.split(":")[1]) if ":" in spec else 60
        result = subprocess.run(
            ["ffprobe", "-v", "error", "-show_entries", "frame=pts_time",
             "-select_streams", "v:0", "-of", "json", input_file],
            capture_output=True, text=True
        )
        scenes = []
        if result.returncode == 0:
            data = json.loads(result.stdout)
            timestamps = []
            for frame in data.get("frames", []):
                t = frame.get("pts_time")
                if t is not None:
                    timestamps.append(float(t))
            timestamps = sorted(set(timestamps))
            for i in range(len(timestamps) - 1):
                seg_len = int(timestamps[i + 1] - timestamps[i])
                if seg_len >= 1:
                    scenes.append((int(timestamps[i]), min(seg_len, max_len)))
        if not scenes:
            print("    No scene changes detected, falling back to head clip")
            clips.append((0, min(max_len, dur)))
        else:
            clips = scenes

    elif spec.startswith("silence:"):
        min_active = int(spec.split(":")[1]) if ":" in spec else 30
        result = subprocess.run(
            ["ffmpeg", "-i", input_file, "-af", "silencedetect=noise=-30dB:d=0.5",
             "-f", "null", "-y", "/dev/null"],
            capture_output=True, text=True
        )
        silences = re.findall(r"silence_start:\s*([\d.]+)\s*\|.*?silence_end:\s*([\d.]+)", result.stderr)
        silence_ranges = [(float(s), float(e)) for s, e in silences]
        active_ranges = []
        prev_end = 0.0
        for s, e in silence_ranges:
            if s - prev_end >= 1.0:
                active_ranges.append((prev_end, s))
            prev_end = e
        if dur - prev_end >= 1.0:
            active_ranges.append((prev_end, float(dur)))
        clips = []
        for start, end in active_ranges:
            seg_len = int(end - start)
            if seg_len >= min_active:
                clips.append((int(start), min(seg_len, 300)))
        if not clips:
            print("    No active sections found, falling back to head clip")
            clips.append((0, min(min_active, dur)))

    elif spec.startswith("rand:") or spec.startswith("random:"):
        range_part = spec.split(":", 1)[1]
        if "-" in range_part and not range_part.startswith("-"):
            parts = range_part.split("-", 1)
            min_len, max_len = int(parts[0]), int(parts[1])
            length = random.randint(min_len, max_len)
        else:
            length = int(range_part)
        if dur <= length:
            clips.append((0, min(length, dur)))
        else:
            offset = random.randint(0, dur - length)
            clips.append((offset, length))

    elif spec.startswith("mid:") or spec.startswith("center:"):
        length = int(spec.split(":")[1])
        if dur <= length:
            clips.append((0, length))
        else:
            offset = (dur - length) // 2
            clips.append((offset, length))

    elif spec.startswith("-"):
        length = int(spec.lstrip("-"))
        if dur <= length:
            clips.append((0, dur))
        else:
            offset = dur - length
            clips.append((offset, length))

    elif "-" in spec:
        parts = spec.split("-", 1)
        start = int(parts[0])
        length = int(parts[1]) - start
        clips.append((start, length))

    else:
        length = int(spec)
        clips.append((0, min(length, dur)))

    return clips

clips = get_clips(spec, total_dur)
if not clips:
    print("No clips to extract.")
    sys.exit(1)

multi = len(clips) > 1
if multi:
    clip_dir = outpath + "_clips"
    os.makedirs(clip_dir, exist_ok=True)
    print(f"  Extracting {len(clips)} clip(s) into {clip_dir}/")
else:
    clip_dir = None

def encode_clip(input_f, start, length, output_f, mode):
    vcodec_args = []
    if mode == "mjpeg":
        vcodec_args = ["-c:v", "mjpeg", "-q:v", "3"]
    else:
        vcodec_args = ["-vf", "scale=trunc(iw/4)*4:trunc(ih/4)*4", "-c:v", "hap", "-format", "hap_q", "-chunks", "4"]

    cmd = [
        "ffmpeg", "-y", "-ss", str(start), "-i", input_f, "-t", str(length),
        *vcodec_args, "-c:a", "pcm_s16le", output_f
    ]
    result = subprocess.run(cmd, capture_output=True, text=True)
    if result.returncode != 0 and mode != "mjpeg":
        print(f"    HAP failed, falling back to MJPEG...")
        cmd = [
            "ffmpeg", "-y", "-ss", str(start), "-i", input_f, "-t", str(length),
            "-c:v", "mjpeg", "-q:v", "3", "-c:a", "pcm_s16le", output_f
        ]
        result = subprocess.run(cmd, capture_output=True, text=True)
    return result.returncode == 0

for i, (start, length) in enumerate(clips):
    if multi:
        out_f = os.path.join(clip_dir, f"clip_{i+1:02d}.mov")
    else:
        out_f = outpath + ".mov"

    m, s = divmod(start, 60)
    print(f"  [{i+1}/{len(clips)}] {m:02d}:{s:02d} +{length}s -> {out_f}")
    encode_clip(input_file, start, length, out_f, mode)

os.remove(input_file)

if multi:
    print(f"Done: {len(clips)} clips in {clip_dir}/")
else:
    print(f"Done: {out_f}")
PYEOF
}

search_videos() {
    local query=""
    local site="yt"
    local max_results=64
    local min_dur=""
    local max_dur=""
    local clip_spec=""
    local download_all=false
    local output_dir="."
    local mode="hap"

    local site_prefix
    local site_name
    local site_url_fmt

    while [[ $# -gt 0 ]]; do
        case $1 in
            --max) max_results="$2"; shift 2 ;;
            --min-dur) min_dur="$2"; shift 2 ;;
            --max-dur) max_dur="$2"; shift 2 ;;
            --site) site="$2"; shift 2 ;;
            --clip) clip_spec="$2"; shift 2 ;;
            -a|--all) download_all=true; shift ;;
            -o) output_dir="$2"; shift 2 ;;
            -j|--jpeg) mode="mjpeg"; shift ;;
            -h|--help) search_usage; return 0 ;;
            *) query="$query $1"; shift ;;
        esac
    done

    case "$site" in
        yt|youtube)
            site_prefix="ytsearch"
            site_name="YouTube"
            site_url_fmt="https://www.youtube.com/watch?v=%(id)s"
            ;;
        sc|soundcloud)
            site_prefix="scsearch"
            site_name="SoundCloud"
            site_url_fmt="%(url)s"
            ;;
        bili|bilibili)
            site_prefix="bilisearch"
            site_name="Bilibili"
            site_url_fmt="%(url)s"
            ;;
        ia|archive)
            archive_search "$query" "$max_results" "$min_dur" "$max_dur" "$download_all" "$output_dir" "$mode" "$clip_spec"
            return $?
            ;;
        *)
            echo "Error: Unknown site '$site'."
            echo "  Supported: yt (YouTube), sc (SoundCloud), bili (Bilibili), ia (Internet Archive)"
            return 1
            ;;
    esac

    query="${query# }"
    if [[ -z "$query" ]]; then
        search_usage
        return 1
    fi

    check_dependencies

    local min_dur_arg="$min_dur"
    local max_dur_arg="$max_dur"

    echo "Searching $site_name: \"$query\" (max $max_results)"

    local tmpfile
    tmpfile=$(mktemp)
    trap "rm -f '$tmpfile'" EXIT

    # Step 1: fetch + filter + display
    python3 - "$tmpfile" "$max_results" "$min_dur_arg" "$max_dur_arg" "${site_prefix}" "$query" << 'PYEOF'
import json, sys, subprocess

tmpfile = sys.argv[1]
max_results = int(sys.argv[2])
min_dur = int(sys.argv[3]) if sys.argv[3] else None
max_dur = int(sys.argv[4]) if sys.argv[4] else None
site_prefix = sys.argv[5]
query = sys.argv[6]

def matches(v):
    dur = int(v.get("duration") or 0)
    if min_dur and dur <= min_dur:
        return False
    if max_dur and dur >= max_dur:
        return False
    return True

# When filtering by duration, fetch the max YouTube can give (~415)
# so we have the largest pool to filter from.
fetch = 500 if (min_dur or max_dur) else max_results
search_query = f"{site_prefix}{fetch}:{query}"
r = subprocess.run(
    ["yt-dlp", "--flat-playlist", "--dump-json", search_query],
    capture_output=True, text=True
)
raw = [json.loads(l) for l in r.stdout.splitlines() if l.strip()]
results = [v for v in raw if matches(v)][:max_results]

if not results:
    print("No matching results found.")
    sys.exit(1)

# Save filtered results for step 2
with open(tmpfile, "w") as f:
    for v in results:
        f.write(json.dumps(v) + "\n")

# Display
for i, v in enumerate(results):
    dur = int(v.get("duration") or 0)
    m, s = divmod(dur, 60)
    ch = v.get("channel", v.get("uploader", "?"))
    t = v.get("title", "?")
    print(f"  [{i+1:2d}] {m:02d}:{s:02d}  {ch}  \u2014  {t}")
print(f"---\n{len(results)} results.")
PYEOF

    local py_exit=$?
    if [[ $py_exit -ne 0 ]]; then
        rm -f "$tmpfile"
        trap - EXIT
        return 1
    fi

    # Step 2: read selection from terminal (bash handles tty properly)
    local selection
    if [[ "$download_all" == true ]]; then
        selection="all"
        echo "Downloading all results."
    else
        echo -n "Select (1 3 5 / 1-5 / a=all / q=quit): "
        read -r selection
        if [[ "$selection" == "q" || -z "$selection" ]]; then
            echo "Cancelled."
            rm -f "$tmpfile"
            trap - EXIT
            return 0
        fi
    fi

    # Step 3: parse selection + download
    python3 - "$tmpfile" "$selection" "$output_dir" "$mode" "$SELF" "$site_url_fmt" "$clip_spec" << 'PYEOF'
import json, sys, subprocess, os

tmpfile = sys.argv[1]
sel = sys.argv[2]
outdir = sys.argv[3]
mode = sys.argv[4]
self_path = sys.argv[5]
url_fmt = sys.argv[6]
clip_spec = sys.argv[7]
results = [json.loads(l) for l in open(tmpfile) if l.strip()]

def parse_selection(sel, n):
    if sel.strip().lower() in ("all", "a"):
        return list(range(n))
    indices = set()
    for part in sel.split():
        if "-" in part and part != "-":
            a, b = part.split("-", 1)
            try:
                indices.update(range(int(a) - 1, int(b)))
            except ValueError:
                pass
        else:
            try:
                indices.add(int(part) - 1)
            except ValueError:
                pass
    return sorted(i for i in indices if 0 <= i < n)

selected = parse_selection(sel, len(results))
if not selected:
    print("Nothing selected.")
    sys.exit(0)

print(f"\nDownloading {len(selected)} video(s)...")
for i, idx in enumerate(selected):
    v = results[idx]
    vid = v["id"]
    title = v.get("title", vid)
    safe = "".join(c if c.isalnum() or c in " -" else "_" for c in title).strip()
    safe = "_".join(safe.split())[:60]
    if not safe:
        safe = vid

    raw_url = v.get("webpage_url", v.get("url", ""))
    if not raw_url:
        raw_url = url_fmt.replace("%(id)s", vid).replace("%(url)s", v.get("url", ""))
    outpath = os.path.join(outdir, safe)

    print(f"\n[{i+1}/{len(selected)}] {title}")
    cmd = [self_path, raw_url, outpath]
    if mode == "mjpeg":
        cmd.append("-j")
    if clip_spec:
        cmd.extend(["--clip", clip_spec])
    try:
        subprocess.run(cmd)
    except KeyboardInterrupt:
        print("\nInterrupted.")
        sys.exit(1)

print("\nDone.")
PYEOF

    rm -f "$tmpfile"
    trap - EXIT
}

archive_search() {
    local query="$1"
    local max_results="$2"
    local min_dur="$3"
    local max_dur="$4"
    local download_all="$5"
    local output_dir="$6"
    local mode="$7"
    local clip_spec="$8"

    check_dependencies

    echo "Searching Internet Archive: \"$query\" (max $max_results)"

    local tmpfile
    tmpfile=$(mktemp)
    trap "rm -f '$tmpfile'" EXIT

    python3 - "$query" "$max_results" "$tmpfile" "$min_dur" "$max_dur" << 'PYEOF'
import json, sys, urllib.request, urllib.parse

query, max_results, outfile, min_dur, max_dur = (
    sys.argv[1], int(sys.argv[2]), sys.argv[3], sys.argv[4], sys.argv[5]
)

q_parts = [query]
if not any(m in query for m in ["mediatype:", "collection:"]):
    q_parts.append("mediatype:(movies OR audio)")
if min_dur:
    q_parts.append(f"duration:>={min_dur}")
if max_dur:
    q_parts.append(f"duration:<={max_dur}")

q = " AND ".join(q_parts)
fields = ["identifier", "title", "year", "duration", "description", "creator", "mediatype"]
params = urllib.parse.urlencode({
    "q": q,
    "rows": max_results,
    "page": 1,
    "output": "json",
})
fl_parts = "&".join(f"fl[]={urllib.parse.quote(f)}" for f in fields)
url = f"https://archive.org/advancedsearch.php?{params}&{fl_parts}"
try:
    with urllib.request.urlopen(url, timeout=15) as resp:
        data = json.loads(resp.read())
except Exception as e:
    print(f"Error querying archive.org: {e}")
    sys.exit(1)

docs = data.get("response", {}).get("docs", [])
if not docs:
    print("No results found.")
    sys.exit(1)

total = data["response"]["numFound"]
results = []
for doc in docs:
    identifier = doc.get("identifier", "?")
    title = doc.get("title", "?")
    year = doc.get("year", "")
    duration = doc.get("duration", "")
    creator = doc.get("creator", "")
    mediatype = doc.get("mediatype", "?")
    results.append({
        "id": identifier,
        "title": title,
        "year": year or "",
        "duration": duration or "",
        "creator": creator or "",
        "mediatype": mediatype,
    })

print(f"---\nShowing {len(results)} of {total} total results.")

for i, r in enumerate(results):
    dur_str = r["duration"]
    if dur_str:
        try:
            secs = int(float(dur_str))
            h, rem = divmod(secs, 3600)
            m, s = divmod(rem, 60)
            if h > 0:
                dur_str = f"{h}:{m:02d}:{s:02d}"
            else:
                dur_str = f"{m:02d}:{s:02d}"
        except ValueError:
            pass
    else:
        dur_str = "--:--"

    year_str = f"[{r['year']}] " if r['year'] else ""
    creator_str = f"{r['creator']}" if r['creator'] else "?"
    mt = r['mediatype'][0].upper()
    print(f"  [{i+1:2d}] {dur_str}  [{mt}] {year_str}{creator_str}  \u2014  {r['title'][:70]}")

with open(outfile, "w") as f:
    for r in results:
        f.write(json.dumps(r) + "\n")
PYEOF

    local rc=$?
    if [[ $rc -ne 0 ]]; then
        rm -f "$tmpfile"
        trap - EXIT
        return $rc
    fi

    local selection
    if [[ "$download_all" == true ]]; then
        selection="all"
        echo "Downloading all results."
    else
        echo -n "Select (1 3 5 / 1-5 / a=all / q=quit): "
        read -r selection
        if [[ "$selection" == "q" || -z "$selection" ]]; then
            echo "Cancelled."
            rm -f "$tmpfile"
            trap - EXIT
            return 0
        fi
    fi

    python3 - "$tmpfile" "$output_dir" "$selection" "$mode" "$SELF" "$clip_spec" << 'PYEOF'
import json, sys, subprocess, os

tmpfile, outdir, sel, mode, self_path, clip_spec = (
    sys.argv[1], sys.argv[2], sys.argv[3], sys.argv[4], sys.argv[5], sys.argv[6]
)
results = [json.loads(l) for l in open(tmpfile) if l.strip()]

def parse_selection(sel, n):
    if sel.strip().lower() in ("all", "a"):
        return list(range(n))
    indices = set()
    for part in sel.split():
        if "-" in part and part != "-":
            a, b = part.split("-", 1)
            try:
                indices.update(range(int(a) - 1, int(b)))
            except ValueError:
                pass
        else:
            try:
                indices.add(int(part) - 1)
            except ValueError:
                pass
    return sorted(i for i in indices if 0 <= i < n)

selected = parse_selection(sel, len(results))
if not selected:
    print("Nothing selected.")
    sys.exit(0)

print(f"\nDownloading {len(selected)} item(s)...")
for i, idx in enumerate(selected):
    r = results[idx]
    identifier = r["id"]
    title = r.get("title", identifier)
    safe = "".join(c if c.isalnum() or c in " -" else "_" for c in title).strip()
    safe = "_".join(safe.split())[:60]
    if not safe:
        safe = identifier

    url = f"https://archive.org/details/{identifier}"
    outpath = os.path.join(outdir, safe)

    print(f"\n[{i+1}/{len(selected)}] {title}")
    cmd = [self_path, url, outpath]
    if mode == "mjpeg":
        cmd.append("-j")
    if clip_spec:
        cmd.extend(["--clip", clip_spec])
    try:
        subprocess.run(cmd)
    except KeyboardInterrupt:
        print("\nInterrupted.")
        sys.exit(1)

print("\nDone.")
PYEOF

    rm -f "$tmpfile"
    trap - EXIT
}

search_usage() {
    echo "Usage: hap-dl search <query> [options]"
    echo ""
    echo "Search media sites, pick results, download + encode to HAP."
    echo ""
    echo "Options:"
    echo "  --site SITE      Site to search (default: yt)"
    echo "                     yt    YouTube (video, full metadata)"
    echo "                     sc    SoundCloud (audio, full metadata)"
    echo "                     bili  Bilibili (video, limited metadata)"
    echo "                     ia    Internet Archive (video + audio, public domain)"
    echo "  --max N          Max results (default: 64)"
