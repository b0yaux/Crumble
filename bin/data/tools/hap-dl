MODE="hap"
PATH_INPUT=""
URL=""
QUICK="false"
CLIP_SPEC=""

if [[ "${1:-}" == "search" ]]; then
    shift
    search_videos "$@"
    exit $?
fi

while [[ $# -gt 0 ]]; do
    case $1 in
        -h|--help) usage ;;
        -q|--quick) QUICK="true"; shift ;;
        -j|--jpeg) MODE="mjpeg"; shift ;;
        --clip) CLIP_SPEC="$2"; shift 2 ;;
        -*) echo "Unknown option: $1"; usage ;;
        *)
            if [[ -z "$URL" ]]; then
                URL="$1"
            elif [[ -z "$PATH_INPUT" ]]; then
                PATH_INPUT="$1"
            fi
            shift
            ;;
    esac
done

if [[ -z "$URL" ]]; then
    usage
fi

check_dependencies

if [[ "$QUICK" == "true" ]]; then
    FINAL_PATH="clip_$(date +%s)"
elif [[ -n "$PATH_INPUT" ]]; then
    FINAL_PATH="$PATH_INPUT"
else
    echo "Fetching title..."
    yt_args "$URL"
    FINAL_PATH=$(yt-dlp "${YT_ARGS[@]}" --get-filename -o "%(title)s" "$URL" | tr '[:upper:]' '[:lower:]' | sed 's/[^a-z0-9]/_/g' | sed 's/__+/_/g' | sed 's/^_//' | sed 's/_$//')
fi

if [[ -n "$CLIP_SPEC" ]]; then
    clip_and_encode "$URL" "$FINAL_PATH" "$MODE" "$CLIP_SPEC"
else
    convert_video "$URL" "$FINAL_PATH" "$MODE"
fi

# ---------------------------------------------------------------------------
# FEED MODE (Planned — Not Implemented)
# ---------------------------------------------------------------------------
#
# Concept: Given a seed video, automatically discover and download related
# videos in a continuous session, building a curated library of encoded content.
#
# Discovery Method:
#
#   YouTube does not expose related videos through yt-dlp (no related_videos
#   field in --dump-json, no --related flag). The YouTube Data API v3 also
#   removed relatedToVideoId. The only viable approach is YouTube's internal
#   innerTube API:
#
#     POST https://www.youtube.com/youtubei/v1/next?key=REDACTED
#     Body: {"context":{"client":{"clientName":"WEB","clientVersion":"2.20240101.00.00"}},"videoId":"VIDEO_ID"}
#
#   Response path (2025-era structure, subject to change):
#     contents.twoColumnWatchNextResults.secondaryResults.secondaryResults.results[]
#       .lockupViewModel.contentId              → video ID
#       .lockupViewModel.metadata.lockupMetadataViewModel.title.content → title
#       .lockupViewModel.metadata.lockupMetadataViewModel.metadata
#         .contentMetadataViewModel.metadataRows[1].metadataParts[0].text.content → views
#       .lockupViewModel.contentImage.thumbnailViewModel.overlays[0]
#         .thumbnailBottomOverlayViewModel.badges[0].thumbnailBadgeViewModel.text → duration
#
#   Returns ~21 algorithmically recommended videos. No API key needed — the key
#   above is hardcoded in every YouTube web client. No per-key rate limit.
#
#   Fallback: Self-hosted Invidious instance
#     GET /api/v1/videos/:id → recommendedVideos[]
#     Public instances are unreliable (legal pressure). Self-hosting required.
#
# Proposed CLI:
#
#   hap-dl feed <url> [options]
#     --depth N          Max hops from seed video (default: 5)
#     --strategy STRAT   How to pick next video from related results:
#                          random     — pick any related video (default)
#                          shortest   — prefer short clips
#                          longest    — prefer long-form
#                          views      — most viewed first
#                          recent     — most recently uploaded
#     --keyword KW       Only follow related videos matching a keyword
#     --max-total-dur    Stop after N total seconds of encoded content
#     --continue FILE    Resume from a saved session state
#     --dry-run          Show what would be downloaded without downloading
#     -j, --jpeg         Force Photo-JPEG encoding
#     -o DIR             Output directory (default: current)
#
# Design Considerations:
#
#   Deduplication — Track all visited video IDs in a set to avoid cycles.
#                   The innerTube API will re-suggest already-seen videos.
#
#   Session persistence — Save queue + history + position to a JSON file
#                         so sessions can be interrupted and resumed.
#
#   Encoding budget — HAP/MJPEG encoding is CPU-heavy (~minutes per video).
#                     --max-total-dur lets you cap total encoded duration
#                     so a session doesn't run for hours unattended.
#
#   Rate limiting — YouTube allows ~300 videos/hour for guest sessions.
#                   Add delays between downloads to avoid throttling.
#
#   innerTube fragility — The response structure changes without notice.
#                         The parser must handle missing fields gracefully.
#                         Consider versioning the expected structure and
#                         falling back to older formats if parsing fails.
#
#   Recommendation bias — Related videos are algorithmic and vary based on
#                         watch history, cookies, and session context.
#                         Anonymous sessions get generic recommendations.
#                         Using cookies from a real account gives more
#                         relevant (but biased) suggestions.
